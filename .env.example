# ─── API KEYS ───────────────────────────────────────────────────
GROQ_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
TAVILY_API_KEY=

# ─── DATABASE ─────────────────────────────────────────────────
POSTGRES_USER=naver_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=naver_advisor

DATABASE_URL=postgresql+asyncpg://naver_user:your_password_here@postgres:5432/naver_advisor
TEST_DATABASE_URL=postgresql+asyncpg://naver_user:your_password_here@localhost:5432/naver_advisor_test

# ─── QDRANT ──────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=smartstore_agent

# ─── JWT ─────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here_minimum_32_chars

# ─── LLM ─────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile

# ─── RAG ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=100
VECTOR_SIZE=1024
TOP_K=5

# ─── MCP ─────────────────────────────────────────────────────────
MCP_SERVER_URL=http://mcp:8001/sse

# ─── LOGS ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
